{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "control-center-width": 380,
  "fit-to-screen": false,

  "widgets": ["title", "dnd", "mpris", "volume", "backlight", "notifications"],

  "widget-config": {
    "title": {
      "text": "Control Center",
      "clear-all-button": true,
      "button-text": "Clear"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "image-size": 96,
      "image-radius": 12
    },
    "volume": {
      "label": "VOL",
      "show-per-app": true
    },
    "backlight": {
      "label": "LGT",
      "device": "amdgpu_bl1"
    },
    "notifications": {}
  }
}
