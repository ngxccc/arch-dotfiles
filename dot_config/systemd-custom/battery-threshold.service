[Unit]
Description=Set ThinkPad Battery Charge Thresholds
After=multi-user.target

[Service]
Type=oneshot
ExecStart=/bin/bash -c '
  for bat in /sys/class/power_supply/BAT*; do
    echo 40 > $bat/charge_control_start_threshold   # ngưỡng bắt đầu sạc
    echo 85 > $bat/charge_control_end_threshold     # ngưỡng dừng sạc
  done
'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
