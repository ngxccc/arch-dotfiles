export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(
  git
  web-search
  colored-man-pages
  command-not-found
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

eval "$(keychain --eval --quiet ngxc)"
eval "$(fnm env --use-on-cd --shell zsh)"

function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

function cz-purge() {
    echo "[!] Đang quét toàn bộ hệ sinh thái (Files & Dirs)..."

    chezmoi managed --include=files,dirs | tac | while IFS= read -r f; do
        local target_path="$HOME/$f"

        # Nếu node không tồn tại vật lý (-e) và không phải broken symlink (-L)
        if [ ! -e "$target_path" ] && [ ! -L "$target_path" ]; then
            
            # Kiểm tra xem nó là file hay thư mục để in log cho chuẩn
            if [ -d "$HOME/$f" ]; then
                echo "[D] Tiễn vong thư mục: $target_path"
            else
                echo "[F] Tiễn vong file: $target_path"
            fi
            
            # Thực hiện lệnh forget
            chezmoi forget "$target_path"
        fi
    done

    echo "[v] Hệ thống đã sạch bóng quân thù!"
}

function backup_pkgs() {
  local backup_dir="$HOME/backup-pkgs"
  mkdir -p "$backup_dir"
  pacman -Qqen > "$backup_dir/pkglist-repo.txt"
  pacman -Qqem > "$backup_dir/pkglist-aur.txt"
  print -P "%F{green}✔ Packages successfully dumped to %f%B$backup_dir%b"
}

alias bpkg='backup_pkgs'
alias sudo='sudo '
alias y='y'
alias vim='nvim'
alias v='nvim'
alias vi='nvim'
